{% snapshot snap_tags %}

{{
    config(
        target_schema='snapshots',
        unique_key="concat(user_id, '-', movie_id, '-', tag)",
        strategy='timestamp',
        updated_at='tag_timestamp',
        invalidate_hard_deletes=True
    )
}}

select
    user_id,
    movie_id,
    tag,
    CAST(tag_timestamp as timestamp_ntz) as rating_timestamp
from {{ ref('src_tags') }}

{% endsnapshot %}